# העתיקי קובץ זה ל-.env.local ומלאי את הפרטים מ-Supabase

# Project URL מהגדרות הפרויקט ב-Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon (public) key מאותו מקום
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# מייל המורה (משמש את ה-trigger ב-DB כדי לסמן role=teacher בהרשמה)
# חשוב: ערך זה גם נשמר ב-Supabase כ-config setting (ראי README, סעיף 4)
TEACHER_EMAIL=teacher@example.com

# כתובת בסיסית לקישורי magic link (לפיתוח: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
